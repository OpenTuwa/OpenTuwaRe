# 1. Rules for your main HTML (The "App" loader)
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# 2. Rules for all Article routes
/articles/*
  Cache-Control: no-cache, no-store, must-revalidate
  # This tells Cloudflare "Edge" to check for a new version every time
  Cloudflare-CDN-Cache-Control: no-cache

# 3. Rules for static assets (CSS/JS) - These CAN be cached for speed
/assets/*
  Cache-Control: public, max-age=31536000, immutable